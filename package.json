{
  "name": "iris-app",
  "version": "0.0.1",
  "private": true,
  "description": "Iris — AI-native, document-centric, terminal-driven project management. The app is a reference implementation of the .iris/ protocol.",
  "license": "AGPL-3.0",
  "main": "out/main/index.js",
  "type": "module",
  "engines": {
    "node": ">=20.0.0"
  },
  "scripts": {
    "dev": "electron-vite dev",
    "build": "npm run typecheck && electron-vite build",
    "preview": "electron-vite preview",
    "typecheck": "tsc --noEmit -p tsconfig.node.json && tsc --noEmit -p tsconfig.preload.json && tsc --noEmit -p tsconfig.web.json",
    "smoke": "node scripts/smoke-launch.mjs",
    "test": "vitest run",
    "test:watch": "vitest",
    "dist": "npm run build && electron-builder --win portable --x64"
  },
  "dependencies": {
    "@xterm/addon-search": "^0.17.0-beta.256",
    "@xterm/addon-serialize": "^0.15.0-beta.256",
    "@xterm/headless": "^6.1.0-beta.256",
    "chokidar": "^5.0.0",
    "gray-matter": "^4.0.3",
    "node-pty": "^1.1.0"
  },
  "devDependencies": {
    "@codemirror/lang-markdown": "^6.5.0",
    "@milkdown/crepe": "^7.21.2",
    "@radix-ui/react-context-menu": "^2.3.0",
    "@radix-ui/react-dialog": "^1.1.0",
    "@radix-ui/react-dropdown-menu": "^2.1.0",
    "@radix-ui/react-slot": "^1.1.0",
    "@radix-ui/react-tooltip": "^1.1.0",
    "@types/node": "^20.14.0",
    "@types/react": "^18.3.3",
    "@types/react-dom": "^18.3.0",
    "@vitejs/plugin-react": "^4.3.1",
    "@xterm/addon-fit": "^0.12.0-beta.256",
    "@xterm/addon-web-links": "^0.13.0-beta.256",
    "@xterm/addon-webgl": "^0.20.0-beta.255",
    "@xterm/xterm": "^6.1.0-beta.256",
    "autoprefixer": "^10.4.19",
    "class-variance-authority": "^0.7.0",
    "clsx": "^2.1.1",
    "codemirror": "^6.0.2",
    "electron": "^31.0.2",
    "electron-builder": "^26.15.2",
    "electron-vite": "^2.2.0",
    "front-cpu": "file:../dashboard/cpu-pipeline",
    "lucide-react": "^1.14.0",
    "postcss": "^8.4.38",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-markdown": "^10.1.0",
    "react-resizable-panels": "^2.1.0",
    "remark-gfm": "^4.0.1",
    "tailwind-merge": "^2.5.0",
    "tailwindcss": "^3.4.4",
    "tailwindcss-animate": "^1.0.7",
    "typescript": "^5.5.2",
    "vite": "^5.3.1",
    "vitest": "^1.6.1"
  }
}
